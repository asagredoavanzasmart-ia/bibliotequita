# =============================================================================
# Variables de entorno — Sistema Biblioteca Personal
# -----------------------------------------------------------------------------
# Copia este archivo a `.env` (que está gitignored) y ajusta los valores.
# En el VPS, define estas variables en tu gestor de procesos (pm2, systemd,
# Docker, etc.) — NO subas el `.env` al repositorio.
# =============================================================================

# --- App ---------------------------------------------------------------------
# Modo de ejecución. En "production" Helmet aplica CSP estricta y se sirven
# los archivos estáticos de dist/ en vez del middleware de Vite.
NODE_ENV=development

# Puerto y host de escucha.
PORT=3000
HOST=0.0.0.0

# Si corres detrás de Nginx en el VPS, ponlo en 1 para que express lea
# X-Forwarded-For correctamente (rate-limit, logs).
TRUST_PROXY=0

# Origen permitido por CORS. En dev "*"; en prod usa tu dominio:
#   CORS_ORIGIN=https://biblioteca.midominio.com
CORS_ORIGIN=*

# --- Almacenamiento de archivos ----------------------------------------------
# Carpeta donde se guardan los PDF/EPUB/portadas subidos. En el VPS apunta a
# un volumen persistente, p. ej. /var/lib/biblioteca/uploads
UPLOAD_DIR=./uploads

# Tope por archivo. Multer rechaza con 413 si se supera.
MAX_UPLOAD_MB=200

# --- Rate limiting -----------------------------------------------------------
# Ventana global y máximo de peticiones por IP a cualquier /api/*.
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=300

# Ventana y máximo más estrictos sólo para los endpoints que llaman a Gemini
# (cuestan dinero).
AI_RATE_LIMIT_WINDOW_MIN=5
AI_RATE_LIMIT_MAX=30

# --- Anti-SSRF en /api/proxy-resource ----------------------------------------
# Si lo dejas vacío, el endpoint sigue funcionando pero bloquea IPs privadas,
# localhost y metadata services. Si quieres restringir aún más a un conjunto
# concreto de dominios, sepáralos por coma:
#   ALLOW_PROXY_HOSTS=arxiv.org,jstor.org,scielo.org
ALLOW_PROXY_HOSTS=

# --- IA ----------------------------------------------------------------------
# Clave para Google Gemini. Crea una en https://aistudio.google.com/app/apikey
# NUNCA versiones el .env real. Si la clave ha estado expuesta, rótala.
GEMINI_API_KEY=

# --- ElevenLabs TTS -----------------------------------------------------------
# Clave de API de ElevenLabs para Text-to-Speech (conseguir en https://elevenlabs.io/app/settings/api-keys)
ELEVENLABS_API_KEY=

# ID de voz por defecto (Rachel - excelente en español y multilingüe)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Autenticación Local ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambiame_por_algo_seguro
SESSION_SECRET=un_secreto_para_la_sesion

# --- Límite de contenidos (demo) ---
# Número máximo de PDF/EPUB que se pueden subir. Predeterminado: 3.
# Ponlo en 0 para desactivar el límite (uso privado sin restricción).
DEMO_MAX_UPLOADS=3

# --- Base de datos (Supabase autoalojado, vía API REST/Kong) -----------------
# URL pública del gateway de Supabase (Kong), ej:
#   SUPABASE_URL=https://influenciadores-app-andres-supabase.rhidmo.easypanel.host
SUPABASE_URL=

# Clave anónima del proyecto (Settings > API en Supabase Studio).
SUPABASE_ANON_KEY=

# Clave de servicio (service_role) — solo para el backend, NUNCA la expongas
# al cliente. Si se define, tiene prioridad sobre SUPABASE_ANON_KEY.
SUPABASE_SERVICE_ROLE_KEY=
